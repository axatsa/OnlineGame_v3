# Database Configuration
POSTGRES_USER=v3_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=online_game_v3

# Security
SECRET_KEY=your_super_secret_key_change_this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# External Services
OPENAI_API_KEY=sk-your-openai-api-key
GEMINI_API_KEYS=your_first_key,your_second_key

# Payment simulate mode (true = skip real bank, go straight to success — for testing)
PAYMENT_SIMULATE=false

# Payment - Payme (Paycom)
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_SECRET_KEY=your_payme_secret_key

# Payment - Click
CLICK_SERVICE_ID=your_click_service_id
CLICK_MERCHANT_ID=your_click_merchant_id
CLICK_SECRET_KEY=your_click_secret_key

# Payment - Plan prices (tiyin = UZS * 100)
PLAN_PRO_PRICE_TIYIN=19000000
PLAN_SCHOOL_PRICE_TIYIN=62000000

# Frontend URL for payment redirects
FRONTEND_URL=http://localhost:5173
